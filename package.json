{
  "name": "yappr",
  "version": "0.1.0",
  "type": "module",
  "description": "pre-publish",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "yappr": "./dist/src/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "config",
    ".env.example"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etherlect/yappr.git"
  },
  "homepage": "https://github.com/etherlect/yappr#readme",
  "bugs": "https://github.com/etherlect/yappr/issues",
  "scripts": {
    "dev": "tsx --conditions=development watch src/yappr.ts",
    "start": "node dist/src/yappr.js",
    "build": "tsc",
    "postbuild": "chmod +x dist/src/cli/index.js",
    "typecheck": "tsc --noEmit",
    "publish:pre": "npm run build && node scripts/publish-pre.mjs",
    "deploy": "tsx src/cli/deploy.ts",
    "ssh": "tsx src/cli/ssh.ts",
    "status": "tsx src/cli/status.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@x402/evm": "^2.13.0",
    "@x402/fetch": "^2.13.0",
    "asciichart": "^1.5.25",
    "better-sqlite3": "^12.10.0",
    "cli-truncate": "^6.0.0",
    "dotenv": "^16.4.5",
    "jiti": "^2.7.0",
    "node-ssh": "^13.0.0",
    "ora": "^9.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "playwright-core": "^1.60.0",
    "string-width": "^8.2.1",
    "twitter-text": "^3.1.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@bankr/cli": "^0.3.1",
    "@types/asciichart": "^1.5.8",
    "@types/node": "^22.0.0",
    "@types/twitter-text": "^3.1.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
